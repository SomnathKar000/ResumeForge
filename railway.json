{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "nixpacks.toml"
  },
  "deploy": {
    "startCommand": "npm start --workspace=apps/server",
    "environmentVariables": {
      "NODE_OPTIONS": "--max-old-space-size=384"
    }
  }
}
